name: titanic-classifier

python_env: python_env.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 5}
      imputation: {type: str, default: "median"}
    command: "python train.py --n-estimators {n_estimators} --max-depth {max_depth} --imputation {imputation}"
